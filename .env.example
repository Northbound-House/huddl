# Copy to .env.local and fill from Firebase Console → Project settings → Your apps → Web app
# Vite only exposes variables prefixed with VITE_

# ============================================================================
# FOR LOCAL DEVELOPMENT - Choose one configuration below
# ============================================================================

# Option 1: Jack Henry Mode (localStorage only, no Firebase)
# Uncomment these lines and leave Firebase config empty:
# VITE_ALLOWED_AUTH_EMAIL_DOMAIN=jackhenry.com
# VITE_USE_FIRESTORE=false
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Option 2: Public Mode (Full Firebase backend)
# Uncomment these lines and fill with your Firebase config:
# VITE_ALLOWED_AUTH_EMAIL_DOMAIN=
# VITE_USE_FIRESTORE=true
# VITE_FIREBASE_API_KEY=your_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
# VITE_FIREBASE_PROJECT_ID=your_project_id_here
# VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
# VITE_FIREBASE_APP_ID=your_app_id_here
# VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# ============================================================================
# CONFIGURATION OPTIONS
# ============================================================================

# Domain restriction for authentication
# - Set to "jackhenry.com" for Jack Henry only
# - Set to empty string "" to allow all domains (public mode)
# - Default: "jackhenry.com"
VITE_ALLOWED_AUTH_EMAIL_DOMAIN=

# Force localStorage mode (disable Firestore)
# - Set to "true" to use Firestore (when Firebase config is present)
# - Set to "false" to force localStorage even if Firebase is configured
# - Default: true (if Firebase configured), false otherwise
VITE_USE_FIRESTORE=

# ============================================================================
# FIREBASE WEB APP CONFIG
# ============================================================================
# Get these from Firebase Console → Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — Google Analytics for Firebase (same as measurementId in console)
VITE_FIREBASE_MEASUREMENT_ID=
