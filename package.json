{
  "name": "huddl",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "build:jackhenry": "vite build --mode jackhenry",
    "build:public": "vite build --mode public",
    "deploy:jackhenry": "npm run build:jackhenry && echo 'Deploy dist/ to Cloudflare Pages or Netlify'",
    "deploy:public": "npm run build:public && firebase deploy --only hosting,firestore,storage",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:firebase": "npm run build && firebase deploy --only hosting,firestore,storage",
    "deploy:functions": "cd functions && npm install && cd .. && firebase deploy --only functions",
    "reset:firestore": "node scripts/resetFirestoreTestData.mjs",
    "reset:firestore:test-data": "node scripts/resetFirestoreTestData.mjs",
    "cleanup:empty-retro-sessions": "node scripts/cleanupEmptyRetroSessions.mjs"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.59.0",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "firebase": "^12.12.0",
    "lucide-react": "^0.460.0",
    "marked": "^18.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "firebase-admin": "^13.0.0",
    "firebase-tools": "^14.27.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  }
}
